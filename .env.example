# 复制本文件为 .env.local 用于本地开发（.env.local 不要提交到 GitHub）
# 部署时，把同样的变量填到 netlify 后台：Site settings → Environment variables

# 后台管理密码。上线前务必改掉。
WENDAO_ADMIN_PASSWORD=请改成强密码

# 本地开发用：true 时验证码会直接返回给页面；正式上线应改成 false 并接短信服务。
WENDAO_MOCK_SMS=true

# 后台选择当前使用哪个 AI。用户前台不选择模型。
# 可选值：deepseek / qwen / openai / claude
WENDAO_AI_PROVIDER=deepseek

# 可选：强制指定具体模型名。不填则使用 lib/config.js 中的默认模型
WENDAO_AI_MODEL=deepseek-v4-flash

# DeepSeek。去 platform.deepseek.com 注册后创建。
DEEPSEEK_API_KEY=

# 通义千问（可选）
DASHSCOPE_API_KEY=

# OpenAI（可选）
OPENAI_API_KEY=

# Claude / Anthropic（可选）
ANTHROPIC_API_KEY=
